# Host path mounted into the container. dev-up.sh rewrites this to an absolute path.
VIDEO_RECOVER_DATA_DIR=./data

# dev-up.sh replaces this placeholder with `openssl rand -hex 32`.
VIDEO_RECOVER_WORKER_TOKEN=change-me

# Native MLX has priority. Enable CPU only if you want Docker to transcribe as fallback.
VIDEO_RECOVER_CPU_FALLBACK_ENABLED=false
VIDEO_RECOVER_NATIVE_WORKER_TIMEOUT_SECONDS=300
VIDEO_RECOVER_MODEL_IDLE_SECONDS=600

# Conservative local limits.
VIDEO_RECOVER_MAX_DOWNLOAD_BYTES=2147483648
VIDEO_RECOVER_MINIMUM_FREE_BYTES=536870912
VIDEO_RECOVER_LOG_LEVEL=INFO
